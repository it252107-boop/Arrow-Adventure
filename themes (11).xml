<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="@color/navicolor">

    <ImageView
        android:id="@+id/settings_icon"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:src="@drawable/ic_settings"
        app:tint="@color/sen"
        android:contentDescription="設定"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_status_confusion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="混乱中…"
        android:textColor="#FF9800"
        android:textSize="24sp"
        android:fontFamily="@font/pixelmplus12regular"
        android:visibility="gone"
        android:background="#80000000"
        android:padding="8dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/direction_arrow"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_circle_white"
        android:padding="40dp"
        android:src="@drawable/ic_arrow_up"
        app:tint="@color/arrow_tint"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.4" />
    <TextView
        android:id="@+id/text_distance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="300m"
        android:textColor="@color/sen"
        android:textSize="50sp"
        android:fontFamily="@font/pixelmplus12regular"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/direction_arrow" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_stop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="中断"
        android:fontFamily="@font/pixelmplus12regular"
        android:textSize="30sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#E53935"
        app:cornerRadius="24dp"
        android:paddingHorizontal="32dp"
        android:paddingVertical="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_distance" />

</androidx.constraintlayout.widget.ConstraintLayout>